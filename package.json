{
  "name": "jarify-vscode",
  "displayName": "Jarify",
  "description": "VS Code extension providing formatting and diagnostics via the jarify CLI",
  "version": "0.1.0",
  "publisher": "amfaro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amfaro/jarify-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension",
  "contributes": {
    "configuration": {
      "title": "Jarify",
      "properties": {
        "jarify.executable": {
          "type": "string",
          "default": "jarify",
          "markdownDescription": "Path to the `jarify` binary. Defaults to `jarify` (resolved from `$PATH`)."
        },
        "jarify.configPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to a `jarify.toml` configuration file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}
